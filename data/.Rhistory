) %>%
mutate(
group = case_when(
author1 == author2 & translator1 != translator2 ~ "Author",
author1 == author2 & translator1 == translator2 ~ "Both same",
author1 != author2 & translator1 == translator2 ~ "Translator",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(group)) %>%
mutate(
group = factor(
group,
levels = c("Author", "Both same", "Translator")
)
)
}
make_boxplot <- function(plot_data, plot_title, file_stub) {
# Summary statistics
summary_stats <- plot_data %>%
group_by(group) %>%
summarise(
n = n(),
mean = mean(value, na.rm = TRUE),
median = median(value, na.rm = TRUE),
sd = sd(value, na.rm = TRUE),
min = min(value, na.rm = TRUE),
max = max(value, na.rm = TRUE),
.groups = "drop"
)
print(summary_stats)
write.csv(
summary_stats,
file.path(output_dir, paste0(file_stub, "_summary_stats.csv")),
row.names = FALSE
)
# Wilcoxon tests
wilcox_results <- tibble(
comparison = c(
"Author vs Translator",
"Both same vs Author",
"Both same vs Translator"
),
p_value = c(
wilcox.test(
value ~ group,
data = plot_data %>% filter(group %in% c("Author", "Translator")),
exact = FALSE
)$p.value,
wilcox.test(
value ~ group,
data = plot_data %>% filter(group %in% c("Both same", "Author")),
exact = FALSE
)$p.value,
wilcox.test(
value ~ group,
data = plot_data %>% filter(group %in% c("Both same", "Translator")),
exact = FALSE
)$p.value
)
)
print(wilcox_results)
write.csv(
wilcox_results,
file.path(output_dir, paste0(file_stub, "_wilcoxon_tests.csv")),
row.names = FALSE
)
# Plot
p <- ggplot(plot_data, aes(x = group, y = value)) +
geom_boxplot(outlier.alpha = 0.2) +
labs(
x = NULL,
y = "Cosine Delta distance",
title = plot_title,
subtitle = "Author = same author/different translators; Both same = same author/same translator; Translator = different authors/same translator"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold"),
axis.text.x = element_text(size = 12)
)
print(p)
ggsave(
file.path(output_dir, paste0(file_stub, ".png")),
plot = p,
width = 8,
height = 6,
dpi = 300
)
ggsave(
file.path(output_dir, paste0(file_stub, ".pdf")),
plot = p,
width = 8,
height = 6
)
}
delta_100 <- get_pairwise_delta(corpus, mfw = 100) %>%
classify_pair_types() %>%
mutate(value = delta)
make_boxplot(
plot_data = delta_100,
plot_title = "Cosine Delta distances at 100 MFWs",
file_stub = "boxplot_100_mfw"
)
write.csv(
delta_100,
