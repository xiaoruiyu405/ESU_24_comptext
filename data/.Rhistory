row.names = FALSE
)
library(stylo)
library(tidyverse)
# -----------------------------
# 1. Paths
# -----------------------------
corpus_dir <- "E:/CSF_final_corpus/CSF_network/corpus"
metadata_path <- "E:/CSF_final_corpus/CSF_network/CSF_metadata.csv"
output_dir <- "E:/CSF_final_corpus/CSF_network/distance_measure"
dir.create(output_dir, recursive = TRUE, showWarnings = FALSE)
# -----------------------------
# 2. Load corpus
# -----------------------------
corpus <- load.corpus.and.parse(
files = "all",
corpus.dir = corpus_dir,
markup.type = "plain",
corpus.lang = "English",
sampling = "no.sampling",
features = "w",
ngram.size = 1,
preserve.case = FALSE,
encoding = "UTF-8"
)
names(corpus) <- names(corpus) %>%
str_remove("\\.txt$") %>%
str_trim()
# -----------------------------
# 3. Load metadata
# -----------------------------
metadata <- read_csv(metadata_path) %>%
mutate(
file_name = str_remove(file_name, "\\.txt$") %>% str_trim(),
author = str_trim(author),
translator = str_trim(translator)
)
# -----------------------------
# 4. Function: pairwise Cosine Delta for one MFW setting
# -----------------------------
get_pairwise_delta <- function(corpus, mfw) {
mfw_list <- make.frequency.list(
data = corpus,
value = FALSE,
head = mfw,
relative = TRUE
)
freq_table <- make.table.of.frequencies(
corpus = corpus,
features = mfw_list,
absent.sensitive = TRUE,
relative = TRUE
)
dist_matrix <- as.matrix(dist.cosine(freq_table))
upper_index <- which(upper.tri(dist_matrix), arr.ind = TRUE)
pairwise_df <- tibble(
text1 = rownames(dist_matrix)[upper_index[, 1]],
text2 = colnames(dist_matrix)[upper_index[, 2]],
delta = dist_matrix[upper_index],
mfw = mfw
)
return(pairwise_df)
}
classify_pair_types <- function(delta_df) {
delta_df %>%
left_join(
metadata %>% select(file_name, author, translator),
by = c("text1" = "file_name")
) %>%
rename(
author1 = author,
translator1 = translator
) %>%
left_join(
metadata %>% select(file_name, author, translator),
by = c("text2" = "file_name")
) %>%
rename(
author2 = author,
translator2 = translator
) %>%
filter(
!is.na(author1),
!is.na(author2),
!is.na(translator1),
!is.na(translator2)
) %>%
mutate(
group = case_when(
author1 == author2 & translator1 != translator2 ~ "Author",
author1 == author2 & translator1 == translator2 ~ "Both same",
author1 != author2 & translator1 == translator2 ~ "Translator",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(group)) %>%
mutate(
group = factor(
group,
levels = c("Author", "Both same", "Translator")
)
)
}
