full_name_clean = str_squish(full_name_clean)
)
View(alumni_clean)
honour_clean <- honour %>%
mutate(
full_name_clean = str_to_lower(Fullname),
full_name_clean = str_squish(full_name_clean)
)
View(honour_clean)
exact_matches <- honour_clean %>%
inner_join(alumni_clean, by = "full_name_clean")
View(exact_matches)
alumni_clean <- alumni_clean %>%
mutate(
first_name = word(full_name_clean, 1),
last_name = word(full_name_clean, -1)
)
honour_clean <- honour_clean %>%
mutate(
first_name = word(full_name_clean, 1),
last_name = word(full_name_clean, -1)
)
name_matches <- honour_clean %>%
inner_join(
alumni_clean,
by = c("first_name", "last_name"),
