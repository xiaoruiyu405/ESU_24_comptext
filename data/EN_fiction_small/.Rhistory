wilcox.test(
value ~ group,
data = plot_data %>% filter(group %in% c("Author", "Translator")),
exact = FALSE
)$p.value,
wilcox.test(
value ~ group,
data = plot_data %>% filter(group %in% c("Both same", "Author")),
exact = FALSE
)$p.value,
